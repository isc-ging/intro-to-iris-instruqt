    <label>Product
      <select name="sku" required>
        <option value="">Loading products...</option>
      </select>
    </label>
    <p id="priceHint" class="price-hint"></p>
    <label>Quantity
      <input type="number" name="quantity" value="1" min="1" required>
    </label>
    <label>City
      <select name="city" required>
        <option value="">Loading cities...</option>
      </select>
    </label>
    <label>Confirmation Email
      <input type="email" name="email" value="customer@example.com" disabled>
    </label>
    <button type="submit" id="submitBtn" disabled>Submit Order</button>
  </form>
  <div id="error"></div>

  <script>
    var productPrices = {};

    async function loadDropdowns() {
      var submitBtn = document.getElementById('submitBtn');
      try {
        var [productsResp, outletsResp] = await Promise.all([
          fetch('/api/holeFoods/products'),
          fetch('/api/holeFoods/outlets')
        ]);
        var products = await productsResp.json();
        var outlets = await outletsResp.json();

        var skuSel = document.querySelector('[name=sku]');
        skuSel.innerHTML = '<option value="">-- Select a product --</option>';
        products.forEach(function(p) {
          productPrices[p.sku] = p.price;
          var opt = document.createElement('option');
          opt.value = p.sku;
          opt.textContent = p.name + ' (' + p.sku + ')';
          if (p.sku === 'SKU-976') opt.selected = true;
          skuSel.appendChild(opt);
        });
        updatePriceHint();

        var citySel = document.querySelector('[name=city]');
        citySel.innerHTML = '<option value="">-- Select a city --</option>';
        outlets.forEach(function(o) {
          var opt = document.createElement('option');
          opt.value = o.city;
          opt.textContent = o.city.charAt(0) + o.city.slice(1).toLowerCase() + ', ' + o.country;
          citySel.appendChild(opt);
        });

        submitBtn.disabled = false;
      } catch (err) {
        document.getElementById('error').textContent = 'Failed to load form data: ' + err.message;
        document.getElementById('error').style.display = 'block';
      }
    }

    function updatePriceHint() {
      var sku = document.querySelector('[name=sku]').value;
      var hint = document.getElementById('priceHint');
      hint.textContent = sku && productPrices[sku] ? 'Price: $' + parseFloat(productPrices[sku]).toFixed(2) + ' each' : '';
    }

    document.querySelector('[name=sku]').addEventListener('change', updatePriceHint);

    document.getElementById('orderForm').addEventListener('submit', async function(e) {
      e.preventDefault();
      var errorDiv = document.getElementById('error');
      errorDiv.style.display = 'none';

      var sku = this.sku.value.trim();
      var quantity = parseInt(this.quantity.value, 10);
      var email = this.email.value.trim();
      var city = this.city.value;

      try {
        var resp = await fetch('/api/holeFoods/order', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ SKU: sku, Quantity: quantity, Email: email, City: city })
        });
        var data = await resp.json();

        if (data.status === 'success') {
          var page = data.emailSent ? 'thankyou.html' : 'thankyou-noemail.html';
          window.location.href = '/csp/user/' + page + '?sku=' + encodeURIComponent(sku) + '&qty=' + quantity;
        } else {
          errorDiv.textContent = data.message || 'Order failed';
          errorDiv.style.display = 'block';
        }
      } catch (err) {
        errorDiv.textContent = 'Connection error: ' + err.message;
        errorDiv.style.display = 'block';
      }
    });

    loadDropdowns();
  </script>
</body>
