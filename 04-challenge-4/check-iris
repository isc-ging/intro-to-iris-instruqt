#!/bin/bash

exec > >(tee /tmp/check-challenge-4.log) 2>&1
set -euxo pipefail

# Check if any orders have been submitted by looking for recent sales transactions
# The interop production should create a SalesTransaction when an order is processed
cat > /tmp/check-orders.cos <<'EOF'
set stmt=##class(%SQL.Statement).%New()
set status=stmt.%Prepare("SELECT COUNT(*) AS cnt FROM HoleFoods.SalesTransaction WHERE Product=?")
set rs=stmt.%Execute("SKU-976")
do rs.%Next()
write rs.cnt
halt
EOF

RESULT=$(su - irisowner -c "iris session IRIS -U USER < /tmp/check-orders.cos" 2>/dev/null | grep -v "^USER>" | grep -v "Node:" | grep -v "^$" | tail -1)

# Trim whitespace
RESULT=$(echo "${RESULT}" | tr -d '\r\n' | xargs)

if [ "${RESULT}" = "0" ]; then
  fail-message "No order has been submitted for SKU-976. Please submit an order using the Shop form."
  exit 1
fi

# Success - an order was submitted
exit 0
