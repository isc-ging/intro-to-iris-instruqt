#!/bin/bash

exec > >(tee /tmp/solve-challenge-3.log) 2>&1
set -euxo pipefail

# Ensure SKU-976 exists and update price to 1.99
cat > /tmp/solve-update.cos <<'EOF'
set stmt=##class(%SQL.Statement).%New()
set status=stmt.%Prepare("SELECT COUNT(*) AS cnt FROM HoleFoods.Product WHERE SKU=?")
set rs=stmt.%Execute("SKU-976")
do rs.%Next()
if rs.cnt = 0 set stmt2=##class(%SQL.Statement).%New()
if rs.cnt = 0 set status=stmt2.%Prepare("INSERT INTO HoleFoods.Product (Category, Name, Price, SKU) VALUES (?, ?, ?, ?)")
if rs.cnt = 0 set status=stmt2.%Execute("Snack", "Gummy Rings", 2.99, "SKU-976")
if rs.cnt = 0 write "Product inserted", !
set stmt3=##class(%SQL.Statement).%New()
set status=stmt3.%Prepare("UPDATE HoleFoods.Product SET Price = ? WHERE SKU = ?")
set status=stmt3.%Execute(1.99, "SKU-976")
write "Price updated to 1.99"
halt
EOF

su - irisowner -c "iris session IRIS -U USER < /tmp/solve-update.cos" 2>/dev/null

exit 0
